{
  "manifest_version": 3,
  "name": "Twitch Flow Chat",
  "version": "1.5.0",
  "description": "Twitchのチャットを配信画面上にニコニコ動画風にスクロールさせます。",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.twitch.tv/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
